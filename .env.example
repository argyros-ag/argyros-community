# ─────────────────────────────────────────────────────────
# Argyros Community — Configuration
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────

# Community mode — must be true
COMMUNITY_MODE=true

# Chain: "fogo" (default) or "solana" (coming soon)
CHAIN=fogo

# ── FluxRPC (required) ────────────────────────────────────
# Get your key at https://fluxrpc.com?ref=ARGYROS
# The binary validates this endpoint at startup with a live call.
RPC_URL=https://eu.fogo.fluxrpc.com?key=YOUR_FLUX_RPC_KEY
YELLOWSTONE_ENDPOINT=https://yellowstone.eu.fogo.fluxrpc.com
YELLOWSTONE_TOKEN=YOUR_FLUX_RPC_KEY

# ── Community license key (required) ─────────────────────
# Register at https://community.argyros.xyz
COMMUNITY_LICENSE_KEY=argycom_xxxxxxxxxxxxxxxxxxxx
COMMUNITY_LICENSE_API=https://license.argyros.xyz

# How often to re-validate the license in the background (default 6h)
# LICENSE_CHECK_INTERVAL=6h


# ── Referral fee (optional — dApp/UI builders only) ──────
# Earn a cut of on-chain protocol fees for swaps you route.
# Leave unset if running the engine for your own bot/internal use.
# REFERRER_WALLET=YourBase58WalletAddress

# ── IP allowlist (optional) ───────────────────────────────
# Restrict access to specific CIDRs. Comma-separated.
# Leave unset for unrestricted access.
# ALLOWED_IPS=10.0.0.0/8,192.168.1.0/24

# ── HTTP server ───────────────────────────────────────────
HTTP_PORT=8080
HTTP_HOST=0.0.0.0
